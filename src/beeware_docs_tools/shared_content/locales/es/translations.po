"    Sponsor: Förderer"
msgstr ""
"INHERIT: config.yml\n"
"site_name: {{ formal_name }} Documentación\n"
"site_url: {% if config.extra.website %}https://beeware.org/de{% else %}https://{{ project_name }}.beeware.org/de{% endif %}\n"
