" \"இது மிகவும் நீண்ட சரமாகும்\"\n"
" \"இது இரண்டு வரிகளுக்குப் பிரிக்கப்பட்டுள்ளது\"\n"
"    ),\n"
"    second_argument,\n"
")"

#: src/beeware_docs_tools/shared_content/en/_shared/contribute/style/code-style-guide.md:67
#, fuzzy
msgid "over:"
msgstr "மேலே:"

#: src/beeware_docs_tools/shared_content/en/_shared/contribute/style/code-style-guide.md:69
