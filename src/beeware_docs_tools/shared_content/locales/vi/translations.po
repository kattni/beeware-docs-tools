msgstr "(.venv) $ tox -m test{{ min_python_version_tag }}"

#: src/beeware_docs_tools/shared_content/en/contribute/how/write-code.md:317
msgid "(.venv) C:\\...>tox -m test{{ min_python_version_tag }}"
msgstr "(.venv) C:\\...>tox -m test{{ min_python_version_tag }}"

